<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="databass.songcatalogapp.controller.SearchController"
      alignment="TOP_CENTER"
      spacing="18"
      styleClass="main-background">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <Label text="Search Songs" styleClass="section-title"/>

    <TextField fx:id="searchField"
               promptText="Search songs or artists..."
               maxWidth="700"
               styleClass="rounded-input"
               onKeyReleased="#onSearchTyping"/>

    <Button text="Search"
            onAction="#onSearchSongsClick"
            styleClass="dark-button"/>

    <ListView fx:id="songListView"
              maxWidth="700"
              prefWidth="700"
              prefHeight="320"
              styleClass="modern-list"/>

    <Button text="Add Selected Song to Playlist"
            onAction="#onAddSelectedSongClick"
            styleClass="dark-button"/>

    <Region VBox.vgrow="ALWAYS"/>

    <HBox spacing="80" alignment="CENTER">
        <Button text="Home" onAction="#onHomeClick" styleClass="nav-button"/>
        <Button text="Search" onAction="#onSearchClick" styleClass="nav-button"/>
        <Button text="Library" onAction="#onLibraryClick" styleClass="nav-button"/>
    </HBox>

</VBox>
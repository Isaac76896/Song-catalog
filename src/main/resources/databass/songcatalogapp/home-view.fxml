<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="databass.songcatalogapp.controller.HomeController"
      alignment="TOP_CENTER"
      spacing="18"
      styleClass="main-background">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <HBox alignment="CENTER_RIGHT" maxWidth="700">
        <Button text="Logout"
                onAction="#onLogoutClick"
                styleClass="nav-button"/>
    </HBox>

    <Label fx:id="welcomeLabel"
           text="Welcome"
           styleClass="section-title"/>

    <TextField fx:id="homeSearchField"
               promptText="Search Music..."
               maxWidth="700"
               styleClass="rounded-input"
               onKeyReleased="#onHomeSearchTyping"
               onAction="#onHomeSearchEnter"/>

    <ListView fx:id="homeSearchResultsList"
              maxWidth="700"
              prefWidth="700"
              prefHeight="180"
              styleClass="modern-list"/>

    <Label text="Your Playlist" styleClass="section-title"/>

    <HBox spacing="15" alignment="CENTER">
        <Button fx:id="playlistButton1"
                prefWidth="250"
                prefHeight="60"
                styleClass="playlist-card"
                onAction="#onPlaylist1Click"/>
        <Button fx:id="playlistButton2"
                prefWidth="250"
                prefHeight="60"
                styleClass="playlist-card"
                onAction="#onPlaylist2Click"/>
    </HBox>

    <HBox spacing="15" alignment="CENTER">
        <Button fx:id="playlistButton3"
                prefWidth="250"
                prefHeight="60"
                styleClass="playlist-card"
                onAction="#onPlaylist3Click"/>
        <Button fx:id="playlistButton4"
                prefWidth="250"
                prefHeight="60"
                styleClass="playlist-card"
                onAction="#onPlaylist4Click"/>
    </HBox>

    <Hyperlink text="+ Create Playlist"
               onAction="#onCreatePlaylistClick"
               styleClass="white-link"/>

    <Region VBox.vgrow="ALWAYS"/>

    <HBox spacing="80" alignment="CENTER">
        <Button text="Home" onAction="#onHomeClick" styleClass="nav-button"/>
        <Button text="Search" onAction="#onSearchClick" styleClass="nav-button"/>
        <Button text="Library" onAction="#onLibraryClick" styleClass="nav-button"/>
    </HBox>

</VBox>
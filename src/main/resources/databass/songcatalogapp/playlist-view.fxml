<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="databass.songcatalogapp.controller.PlaylistController"
      alignment="TOP_CENTER"
      spacing="18"
      styleClass="main-background">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <Label fx:id="playlistTitleLabel" text="Playlist" styleClass="section-title"/>

    <ListView fx:id="songListView"
              maxWidth="700"
              prefWidth="700"
              prefHeight="350"
              styleClass="modern-list"/>

    <HBox spacing="15" alignment="CENTER">
        <Hyperlink text="+ Add Song"
                   onAction="#onAddSongClick"
                   styleClass="white-link"/>

        <Button text="Remove Selected Song"
                onAction="#onRemoveSelectedSongClick"
                styleClass="dark-button"/>
    </HBox>

    <Region VBox.vgrow="ALWAYS"/>

    <HBox spacing="80" alignment="CENTER">
        <Button text="Home" onAction="#onHomeClick" styleClass="nav-button"/>
        <Button text="Search" onAction="#onSearchClick" styleClass="nav-button"/>
        <Button text="Library" onAction="#onLibraryClick" styleClass="nav-button"/>
    </HBox>

</VBox>